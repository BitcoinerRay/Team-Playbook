{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Registry",
  "description": "Team Playbook registry index",
  "type": "object",
  "required": ["schema_version", "built_at", "modules", "presets"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "type": "string", "description": "Registry format version" },
    "built_at": { "type": "string", "format": "date-time", "description": "ISO8601 build timestamp" },
    "modules": {
      "type": "array",
      "items": { "$ref": "./module.json" }
    },
    "presets": {
      "type": "array",
      "items": { "$ref": "./preset.json" }
    }
  }
}
